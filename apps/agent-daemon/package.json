{
  "name": "agent-loop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Distributed agent loop daemon — GitHub Issues as task queue",
  "bin": {
    "agent-loop": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@agent/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  }
}
